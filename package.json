{
  "name": "blog-momo",
  "version": "1.0.0",
  "description": "Momo Platform Blog - Natural affiliate blog",
  "type": "module",
  "scripts": {
    "dev": "remix vite:dev",
    "build": "remix vite:build",
    "bundle": "esbuild worker.ts --bundle --outfile=dist/worker.mjs --format=esm --platform=neutral --target=es2022 --external:@remix-run/cloudflare-workers --external:@remix-run/cloudflare",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute blog-momo-db --remote --file",
    "db:migrate:local": "wrangler d1 execute blog-momo-db --local --file"
  },
  "dependencies": {
    "@remix-run/cloudflare": "^2.15.1",
    "@remix-run/cloudflare-pages": "^2.17.4",
    "@remix-run/cloudflare-workers": "^2.15.1",
    "@remix-run/react": "^2.15.1",
    "hono": "^4.6.14",
    "isbot": "^5.1.17",
    "marked": "^17.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@remix-run/dev": "^2.15.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wrangler": "^3.99.0"
  }
}
